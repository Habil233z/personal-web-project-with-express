
        <div class="formProjectContainer">
            <button class="backButton" onclick="back()">Back</button>
            <h1 id="myProjecth1">Add New Project</h1>

                <form id="myProjectForm">
                    <h2>Project Name</h2>
                        <input type="text" id="projectName">
                    <h2>Description</h2>
                        <input type="text" id="projectDescription">
                    <h2>Tag</h2>
                        <select id="projectTag">
                            <option value="none">None</option>
                            <option value="technology">Technology</option>
                            <option value="sport">Sport</option>
                            <option value="construction">Construction</option>
                            <option value="decoration">decoration</option>
                        </select>
                    <div class="imgUpload">
                    <h2>images</h2>
                    <input type="file" name="" id="fileId" onchange="imageUploaded()">
                    </div>
                    <button type="submit" id="submitButton">submit</button>
                </form>
                <button onclick="clearAll()" id="clearAllButton">clear all</button>
        </div>

        <div class="myProjectContainer">
            <div class="filterArea">
                <h2>Filter by Tag</h2>
                    <select id="filterTag" onchange="filterProjects()">
                        <option value="none">None</option>
                        <option value="technology">Technology</option>
                        <option value="sport">Sport</option>
                        <option value="construction">Construction</option>
                        <option value="decoration">decoration</option>
                    </select>
            </div>
            <div id="containerArea">
            </div>
        </div>

    <script src="../assets/scripts/index.js"></script>
